{
  "name": "sat-overlay",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs chrome",
    "build:firefox": "node scripts/build.mjs firefox",
    "build:edge": "node scripts/build.mjs edge",
    "dev:chrome": "node scripts/dev-chrome.mjs",
    "reload": "node scripts/reload-ext.mjs",
    "reload:build": "node scripts/build.mjs chrome && node scripts/reload-ext.mjs",
    "cdp": "node scripts/cdp-eval.mjs",
    "drift:probe": "npm run cdp -- --file scripts/probe-fingerprint.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^22.19.21",
    "esbuild": "^0.24.0",
    "fake-indexeddb": "^6.0.0",
    "happy-dom": "^15.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "idb": "^8.0.0"
  }
}
