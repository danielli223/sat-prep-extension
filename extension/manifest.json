{
  "manifest_version": 3,
  "name": "Focused Practice",
  "version": "0.0.1",
  "description": "Scoring, a mistake journal, weak-area tracking, and a calculator that work on top of the official SAT Question Bank.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "*://satsuiteeducatorquestionbank.collegeboard.org/*",
    "*://mypractice.collegeboard.org/*",
    "https://config.focusedpractice.app/*",
    "https://us.i.posthog.com/*",
    "https://api.focusedpractice.app/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "*://satsuiteeducatorquestionbank.collegeboard.org/*",
        "*://mypractice.collegeboard.org/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": { "default_title": "Focused Practice", "default_popup": "popup.html" }
}
