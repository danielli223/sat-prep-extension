{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "statusMessage": "Rebuilding labeled extension/dist…",
            "command": "INPUT=$(cat); D=$(printf '%s' \"$INPUT\" | jq -r '.cwd // \".\"'); S=\"$D/extension/scripts/dev-autobuild-hook.sh\"; [ -f \"$S\" ] && bash \"$S\" \"$D\"; exit 0"
          }
        ]
      }
    ]
  }
}
